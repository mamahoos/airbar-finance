# Production environment template — copy to `.env.production` on the deploy server.
# Never commit `.env.production` or production secrets.

POSTGRES_USER=airbar
POSTGRES_PASSWORD=change-me-production
POSTGRES_DB=airbar_finance
REDIS_DB=1

HTTP_PORT=8080
GRPC_PORT=50051

ZIBAL_SANDBOX=false
ZIBAL_MERCHANT=your_production_merchant_id
FINANCE_PUBLIC_BASE_URL=https://finance.example.com
PLATFORM_FEE_PERCENT=10

# Create the shared network once on the server:
#   docker network create airbar-prod
# airbar-core resolves finance gRPC at airbar-finance-app-prod:50051 on this network.
