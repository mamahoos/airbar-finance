# Staging environment template — copy to `.env.staging` on the deploy server.
# Never commit `.env.staging` or production secrets.

POSTGRES_USER=airbar
POSTGRES_PASSWORD=change-me-staging
POSTGRES_DB=airbar_finance_staging
POSTGRES_PORT=5436

REDIS_PORT=6383
REDIS_DB=1

APP_PORT=8082
GRPC_PORT=50053
HTTP_PORT=8080

ZIBAL_SANDBOX=true
ZIBAL_MERCHANT=zibal
FINANCE_PUBLIC_BASE_URL=https://finance-staging.example.com
PLATFORM_FEE_PERCENT=10

# Create the shared network once on the server:
#   docker network create airbar-staging
