# Staging on company VPS (/srv/airbar.app/airbar-finance/)
# Copy to `.env.staging` on the server. Never commit secrets.
#
# Shared infra from airbar-infra (already on airbar-net):
#   airbar-postgres, airbar-redis
#
# One-time DB bootstrap on server:
#   docker exec -it airbar-postgres psql -U postgres -c \
#     "CREATE DATABASE airbar_finance_staging OWNER airbar;"

POSTGRES_USER=airbar
POSTGRES_PASSWORD=change-me-staging
POSTGRES_DB=airbar_finance_staging

DATABASE_URL=postgresql://airbar:change-me-staging@airbar-postgres:5432/airbar_finance_staging?sslmode=disable
REDIS_URL=redis://airbar-redis:6379/1

HTTP_PORT=8080
GRPC_PORT=50051

ZIBAL_SANDBOX=true
ZIBAL_MERCHANT=zibal
FINANCE_PUBLIC_BASE_URL=https://staging.finance.airbar.app
PLATFORM_FEE_PERCENT=10
