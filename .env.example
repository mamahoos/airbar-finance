# Copy to .env for local development:
#   cp .env.example .env
#
# Production: inject all variables via your orchestrator (Kubernetes secrets, ECS, etc.).
# Never commit .env or production secrets to git.

# --- Database (required) ---
# These values must match docker-compose.yml POSTGRES_* variables
POSTGRES_USER=airbar
POSTGRES_PASSWORD=airbar
POSTGRES_DB=airbar_finance
POSTGRES_PORT=5434

# Local binary against docker-compose postgres (uses above variables):
DATABASE_URL=postgres://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=disable

# --- Redis (required) ---
REDIS_PORT=6381
REDIS_INTERNAL_PORT=6379
REDIS_DB=1

# Local binary against docker-compose redis (uses above variables):
REDIS_URL=redis://localhost:${REDIS_PORT}/${REDIS_DB}

# --- Server ports (required) ---
GRPC_PORT=50051
HTTP_PORT=8080

# --- Zibal PSP (required) ---
# Sandbox: ZIBAL_SANDBOX=true and ZIBAL_MERCHANT=zibal
# Production: ZIBAL_SANDBOX=false and ZIBAL_MERCHANT=<your_merchant_id>
ZIBAL_SANDBOX=true
ZIBAL_MERCHANT=zibal

# --- Public edge URL (required) ---
# Used to build PSP callback URLs in F4+. Must be reachable by Zibal in production.
FINANCE_PUBLIC_BASE_URL=http://localhost:8080

# --- Platform fee (required) ---
PLATFORM_FEE_PERCENT=10